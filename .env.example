# ── API Keys ───────────────────────────────────────────────────────────────
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── PostgreSQL (Supabase) ──────────────────────────────────────────────────
# Obtén en: https://supabase.com → tu proyecto → Settings → Database → URI
# Región recomendada: East US (North Virginia) — menor latencia desde Colombia
POSTGRES_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Qdrant Cloud ───────────────────────────────────────────────────────────
# Obtén en: https://cloud.qdrant.io → tu cluster → API keys
# Región recomendada: GCP us-east4
QDRANT_URL=https://[CLUSTER_ID].[REGION].gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=[TU_API_KEY_DE_QDRANT_CLOUD]
QDRANT_COLLECTION=elempleo_jobs

# ── LLM Gateway ───────────────────────────────────────────────────────────
GATEWAY_URL=http://localhost:8000
LLM_MODEL_SONNET=claude-sonnet-4-6
LLM_MODEL_HAIKU=claude-haiku-4-5-20251001

# ── WhatsApp Sandbox (Meta) ────────────────────────────────────────────────
# Obtén en: https://developers.facebook.com/
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=elempleo_poc_verify

# ── Email Sandbox (Mailtrap) ───────────────────────────────────────────────
# Obtén en: https://mailtrap.io/
MAILTRAP_TOKEN=
MAILTRAP_INBOX_ID=

# ── Entorno ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
